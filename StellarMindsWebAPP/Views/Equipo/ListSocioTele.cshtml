@using StellarMindsWebApp.AuxiliarViewmodel

@model SociosPorTelescopioViewmodel

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">
        @ViewBag.Error
    </div>
}

<form method="post">

    <select name="telescopioId">
        <option value="">
            Seleccione un telescopio
        </option>

        @foreach (TelescopioModel tele in Model.Telescopios)
        {
            <option value="@tele.Id">
                @tele.Marca - @tele.Modelo
            </option>
        }

    </select>

    <input type="submit" value="Buscar" />

</form>

@if (Model.Socios.Any())
{
    <table class="table">

        @foreach (UsuarioModel socio in Model.Socios)
        {
            <tr>
                <td>@socio.Nombre</td>
                <td>@socio.Email</td>
            </tr>
        }

    </table>
}
else
{
    <p>Este telescopio aún no se ha prestado.</p>
}