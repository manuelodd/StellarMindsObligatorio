@using DTOs.DTOs
@model IEnumerable<PrestamoDTO>

    @if (Context.Session.GetString("rol") == "ADMINISTRADOR")
{
    <a asp-controller="Prestamo" asp-action="Create">
        Crear prestamo
    </a>
}
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Id)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.FechaInicio)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.FechaFin)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Estado)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TelescopioID)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.MonturaID)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CamaraID)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.OcularID)
            </th>
            
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (PrestamoDTO item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Id)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.FechaInicio)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.FechaFin)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Estado)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.TelescopioID)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.MonturaID)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.CamaraID)
                </td>

                <td>
                    @Html.DisplayFor(modelItem => item.OcularID)
                </td>
                <td>
                    @Html.ActionLink("Edit", "Edit", new { /* id=item.PrimaryKey */ }) |
                    @Html.ActionLink("Details", "Details", new { /* id=item.PrimaryKey */ }) |
                    @Html.ActionLink("Return", "Return", new { id=item.Id })
                </td>
            </tr>
        }
    </tbody>
</table>
